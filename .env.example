DRY_RUN=true
POLL_INTERVAL_SECONDS=60
TMP_DIR=data/tmp
TEMPLATE_CONFIG=config/templates.yaml
DATABASE_URL=sqlite:///data/report_store.db
REPORT_PDF_DIR=data/reports/pdf
DETAIL_BASE_URL=http://127.0.0.1:8001
# 服务器部署时填公网入口，由 Nginx 80/443 转发到本机详情页服务。
# 示例：http://123.57.19.15 或 https://reports.example.com
PUBLIC_BASE_URL=

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_REPORT_TABLE_ID=
FEISHU_ITEM_TABLE_ID=
FEISHU_WIDE_TABLE_ID=tbl9HYZJwXIFjmEF
# wide=管理员直接在产品检测值宽表上传 PDF 并回填同一行；report=旧版检测报告主表入口。
FEISHU_UPLOAD_TABLE_MODE=wide
FEISHU_BOT_WEBHOOK=
FEISHU_FOLDER_TOKEN=
FEISHU_OUTPUT_BITABLE_NAME=宠物食品检测报告解析结果
FEISHU_ARCHIVE_ENABLED=false
FEISHU_ARCHIVE_CONFIG=config/archive_folders.csv
FEISHU_ARCHIVE_RULES=config/archive_rules.yaml
# 共享文件夹（归档根目录）token，取自飞书云盘文件夹链接 /drive/folder/<token>
FEISHU_ARCHIVE_ROOT_TOKEN=
FEISHU_ARCHIVE_DOMAIN=https://zb6okqgl47.feishu.cn
# 可选：创建多维表格后自动设置链接权限。
# 空值=不修改权限；tenant_editable=组织内获得链接的人可编辑；anyone_editable=互联网上获得链接的人可编辑。
FEISHU_LINK_SHARE_ENTITY=tenant_editable

FIELD_PDF=PDF附件
FIELD_STATUS=解析状态
FIELD_ERROR=错误原因
FIELD_REPORT_NO=报告编号
FIELD_BRAND_NAME=品牌名称
FIELD_PRODUCT_NAME=产品名称
FIELD_SAMPLE_NAME=样品名称
FIELD_LAB=检测机构
FIELD_CLIENT=委托单位
FIELD_REPORT_DATE=报告日期
FIELD_CONCLUSION=报告结论
FIELD_CATEGORY=产品分类
FIELD_TEMPLATE=解析模板
FIELD_RELATED_REPORT=关联报告
FIELD_EXTRA_INFO=其他信息JSON
FIELD_RAW_TEXT=原文文本
FIELD_ITEM_EXTRA_INFO=明细额外信息JSON
FIELD_DETAIL_URL=详情页链接
FIELD_ARCHIVE_URL=归档文件链接
FIELD_ARCHIVE_PATH=归档路径
FIELD_ARCHIVE_ERROR=归档错误
